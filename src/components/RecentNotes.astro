---
// src/components/RecentNotes.astro
import { getCollection } from 'astro:content';

const { limit = 5, showAllLink = true } = Astro.props;

const recentNotes = (await getCollection('docs', ({ id, data }) => {
  return id.startsWith('learning-log/') && !data.draft;
}))
  .sort((a, b) => {
    const aTime = a.data.date ? new Date(a.data.date).getTime() : 0;
    const bTime = b.data.date ? new Date(b.data.date).getTime() : 0;
    return bTime - aTime;
  });

const visibleNotes = typeof limit === 'number' && limit > 0
  ? recentNotes.slice(0, limit)
  : recentNotes;

const formatDate = (value) => {
  if (!value) return '';
  return new Date(value).toLocaleDateString('es-ES');
};

const getTag = (data) => {
  if (typeof data.tag === 'string' && data.tag.trim()) return data.tag;
  if (Array.isArray(data.tags) && data.tags.length > 0) return data.tags[0];
  return 'learning-log';
};

const getNoteText = (data) => {
  if (typeof data.summary === 'string' && data.summary.trim()) return data.summary;
  if (typeof data.description === 'string' && data.description.trim()) return data.description;
  return data.title;
};

const getHref = (note) => {
  if (note.slug) return `/${note.slug}/`;
  const id = note.id.replace(/\\/g, '/').replace(/\.mdx?$/, '');
  const normalized = id.endsWith('/index') ? id.slice(0, -('/index'.length)) : id;
  return `/${normalized}/`;
};
---
<table>
  <thead>
    <tr>
      <th>Tag</th>
      <th>Date</th>
      <th>Note</th>
    </tr>
  </thead>
  <tbody>
    {visibleNotes.map((note) => (
      <tr>
        <td class="tag">{getTag(note.data)}</td>
        <td class="date">{formatDate(note.data.date)}</td>
        <td class="note">
          <a href={getHref(note)}>
            {getNoteText(note.data)}
          </a>
        </td>
      </tr>
    ))}
  </tbody>
</table>

{showAllLink && (
  <div class="recent-notes-footer">
    <a class="recent-notes-link" href="/learning-log">Ver todo</a>
  </div>
)}

<style>
  .recent-notes-footer {
    margin-top: 0.75rem;
    display: flex;
    justify-content: flex-start;
  }
  .recent-notes-link {
    text-decoration: underline;
    font-weight: 600;
  }
</style>

